# ── Qdrant ───────────────────────────────────────────────
# Local:  leave QDRANT_URL as default, no API key needed
# Cloud:  set QDRANT_URL to your cluster URL and add QDRANT_API_KEY
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# ── LLM (OpenAI-compatible endpoint) ─────────────────────
# Default: Groq (free tier at console.groq.com)
# Alt:     DashScope — set BASE_URL to https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://api.groq.com/openai/v1
DASHSCOPE_API_KEY=your_api_key

TEXT_MODEL=llama-3.3-70b-versatile
VISION_MODEL=llama-3.3-70b-versatile

# ── Embedding ─────────────────────────────────────────────
# Local sentence-transformers model, no API key needed
# Override only if using a different embedding model
EMBED_MODEL=text-embedding-v4
VECTOR_SIZE=384

# ── TTS (optional) ───────────────────────────────────────
# Provide one to enable server-side text-to-speech
# If neither is set, the frontend falls back to browser TTS
OPENAI_API_KEY=
